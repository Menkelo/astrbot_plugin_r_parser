{
    "disabled_sessions": {
        "description": "关闭解析的会话",
        "hint": "在会话中使用命令 “开启解析” 和 “关闭解析” 来设置某会话的解析状态",
        "type": "list",
        "default": []
    },
    "arbiter": {
        "description": "响应提示",
        "hint": "开启后，当 Bot 识别到链接并开始解析时，会对消息贴表情（仅 OneBot V11 有效），作为视觉反馈",
        "type": "bool",
        "default": true
    },
    "performance": {
        "description": "性能配置",
        "type": "object",
        "items": {
            "max_concurrent_downloads": {
                "description": "最大并发下载数",
                "hint": "类似于 p-queue，限制同时进行的下载任务数量，防止网络拥堵或风控。建议 3-5。",
                "type": "int",
                "slider": {
                    "min": 1,
                    "max": 20,
                    "step": 1
                },
                "default": 6
            },
            "source_max_size": {
                "description": "资源最大大小",
                "hint": "允许下载的音视频最大体积，单位 MB",
                "type": "int",
                "slider": {
                    "min": 10,
                    "max": 500,
                    "step": 10
                },
                "default": 90
            }
        }
    },
    "cookies": {
        "description": "Cookie 配置",
        "type": "object",
        "items": {
            "douyin_ck": {
                "description": "抖音 Cookie",
                "hint": "抖音网页版 Cookie，用于获取更高画质或解决风控问题 (yt-dlp 兜底必需)",
                "type": "string",
                "default": ""
            },
            "bili_ck": {
                "description": "Bilibili Cookies",
                "hint": "用于B站解析的登录Cookies，留空则使用无登录状态",
                "type": "string",
                "default": ""
            }
        }
    },
    "data_dir": {
        "description": "数据目录",
        "type": "string",
        "invisible": true
    },
    "cache_dir": {
        "description": "缓存目录",
        "type": "string",
        "invisible": true
    }
}
